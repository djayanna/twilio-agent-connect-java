# Twilio Agent Connect - Environment Configuration
# Copy this file to .env and fill in your actual values

# ============================================================================
# REQUIRED CREDENTIALS
# ============================================================================

# 1. Account SID - Your Twilio account identifier (starts with AC)
#    Find at: https://console.twilio.com/us1/account/keys-credentials/api-keys
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 2. Auth Token - Your account authentication token
#    Find at: https://console.twilio.com/us1/account/keys-credentials/api-keys
#    WARNING: Use API Keys for production (see below)
TWILIO_AUTH_TOKEN=your_auth_token_here

# 3. API Key SID - Standard API Key for production use (starts with SK)
#    Create at: https://console.twilio.com/us1/account/keys-credentials/api-keys
#    Click "Create API key" > Standard > Copy the SID and Secret
TWILIO_API_KEY=SKxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 4. API Secret - Secret for the API Key above
#    IMPORTANT: Only shown once at creation - save it immediately!
TWILIO_API_SECRET=your_api_secret_here

# 5. Conversation Configuration ID (starts with IG)
#    Create via CLI: twilio api:conversations:v1:configuration:create --auto-create-conversations
#    Or via Console: https://console.twilio.com/us1/develop/conversations/manage/configurations
TWILIO_CONVERSATION_CONFIGURATION_ID=IGxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 6. Phone Number - Your Twilio phone number in E.164 format
#    Buy at: https://console.twilio.com/us1/develop/phone-numbers/search
TWILIO_PHONE_NUMBER=+15551234567

# ============================================================================
# OPTIONAL - VOICE CONFIGURATION
# ============================================================================

# Public domain for voice webhooks (required for voice features)
# Use ngrok during development: https://ngrok.com
# Example: https://abc123.ngrok.io
TWILIO_VOICE_PUBLIC_DOMAIN=https://your-domain.com

# Human-agent handoff destination (optional). When set, the AI can transfer a
# voice call to this E.164 number. Leave blank to disable handoff.
TWILIO_HANDOFF_AGENT_NUMBER=+15551234567

# ============================================================================
# OPTIONAL - MEMORY CONFIGURATION
# ============================================================================

# Memory Store ID (starts with MEM) - for persistent conversation memory
# Create at: https://console.twilio.com/us1/develop/memory
# Or via API: curl -X POST https://memory.twilio.com/v1/MemoryStores \
#   -u "$TWILIO_API_KEY:$TWILIO_API_SECRET" \
#   -d "FriendlyName=MyAgentMemory"
TWILIO_MEMORY_STORE_ID=MEMxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Trait groups (comma-separated, optional)
TWILIO_TRAIT_GROUPS=customer_profile,preferences

# ============================================================================
# OPTIONAL - LLM CONFIGURATION (for examples)
# ============================================================================

# OpenAI API Key - for OpenAI examples
# Get one at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxx
